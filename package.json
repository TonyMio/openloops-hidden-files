{
  "name": "openloops-hidden-files",
  "version": "1.0.0",
  "description": "Reveal chosen dot-folders in Obsidian's native file-explorer tree.",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "release": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs release",
    "check": "tsc -noEmit -skipLibCheck",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "TonyMio",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
